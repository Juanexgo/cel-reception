generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
  TECHNICIAN
}

enum Brand {
  APPLE
  SAMSUNG
  HUAWEI
  XIAOMI
  OPPO
  VIVO
  MOTOROLA
  LG
  GOOGLE
  ONEPLUS
  NOKIA
  SONY
  ZTE
  OTHER
}

enum ReceptionStatus {
  RECEIVED
  DIAGNOSING
  WAITING_PARTS
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
}

enum AuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  DELIVER
  DELETE
  DELETE_CLIENT
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  password      String
  role          UserRole      @default(EMPLOYEE)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  receptions    Reception[]   @relation("AssignedTechnician")
  auditLogs     AuditLog[]
}

model Client {
  id          String        @id @default(cuid())
  name        String
  phone       String        @unique
  email       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  // Soft-delete: rows with `deletedAt` set are hidden from list/search but
  // remain referenced by historical receptions, so we never break FK
  // integrity for completed orders.
  deletedAt   DateTime?
  receptions  Reception[]
  auditLogs   AuditLog[]

  @@index([deletedAt])
}

model Reception {
  id              String          @id @default(cuid())
  // Sequential numeric ID backed by a Postgres sequence (Reception_folioNumber_seq).
  // The visible folio is derived as `REC-${folioNumber}` so it grows without
  // any digit cap (REC-1, REC-10, REC-1000, REC-1000000, ...).
  // The sequence is owned by this column, so concurrent inserts get unique
  // numbers atomically — no race conditions.
  folioNumber     Int             @unique @default(autoincrement())
  folio           String          @unique
  trackingToken   String          @unique
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  technicianId    String?
  technician      User?           @relation("AssignedTechnician", fields: [technicianId], references: [id])
  brand           Brand
  model           String
  color           String
  imei            String?
  problem         String
  accessories     String
  status          ReceptionStatus @default(RECEIVED)
  totalCost       Float           @default(0)
  signatureData   String?
  signatureDate   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  statusHistory   StatusHistory[]
  payments        Payment[]
  auditLogs       AuditLog[]

  @@index([deletedAt])
}

model StatusHistory {
  id           String          @id @default(cuid())
  receptionId  String
  reception    Reception       @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  status       ReceptionStatus
  notes        String?
  createdAt    DateTime        @default(now())
}

model Payment {
  id            String          @id @default(cuid())
  receptionId   String
  reception     Reception       @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  amount        Float
  method        PaymentMethod
  concept       String
  reference     String?
  status        PaymentStatus   @default(PAID)
  createdAt     DateTime        @default(now())
}

/// Append-only audit trail. Originally per-reception, now also captures
/// client-level events (e.g. DELETE_CLIENT). Exactly one of `receptionId`
/// or `clientId` is set per row; the action enum disambiguates the entity.
///
/// - `userId` is nullable + ON DELETE SET NULL so we never lose history when
///   a user account is removed; we still keep the snapshotted name/email so
///   the UI can render the actor without joining a possibly-missing row.
/// - `clientId` uses ON DELETE SET NULL to keep the audit row even if a hard
///   delete ever bypasses the soft-delete path.
/// - `metadata` is a free-form JSON blob whose shape varies per `action`
///   (see audit-repository for the typed builders).
model AuditLog {
  id           String      @id @default(cuid())
  receptionId  String?
  reception    Reception?  @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName     String
  userEmail    String
  action       AuditAction
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([receptionId, createdAt])
  @@index([clientId, createdAt])
}
